{
  "expo": {
    "name": "Jump Logs",
    "slug": "skydivelog",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skydivelog.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Used to log jumps by voice.",
        "NSMicrophoneUsageDescription": "Used to record your jump description for voice logging.",
        "NSPhotoLibraryUsageDescription": "Used to attach photos to your jump log entries."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.skydivelog.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0A84FF",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#060e1a"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      "expo-speech-recognition",
      ["expo-audio", { "enableBackgroundPlayback": false, "enableBackgroundRecording": false }],
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc9dfbc1-3566-496f-acab-5b307fcbbd2a"
      }
    }
  }
}
